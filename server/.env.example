# --- Development (default local work) ---
RAILS_ENV=development
PORT=3000

# Sign in with Apple and app auth will be wired in later phases.
APPLE_TEAM_ID=
APPLE_SERVICE_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=

# Initial machine-to-machine auth placeholder for the Mac agent.
AGENTKVT_AGENT_TOKEN=replace-me

# --- Production (copy values into server/.env on the Mac server) ---
# RAILS_ENV=production
# SECRET_KEY_BASE=   # required: run `cd server && bundle exec rails secret`
# AGENTKVT_ALLOW_HTTP=1
# AGENTKVT_BIND_ALL_INTERFACES=1
# BIND_IP=0.0.0.0
# Optional explicit bind instead of BIND_IP:
# AGENTKVT_BIND_ALL_INTERFACES=0
# BIND_IP=100.x.x.x

# Webhook HMAC secret — must match AGENTKVT_WEBHOOK_SECRET stored in the Mac runner's Keychain.
# Generate with: openssl rand -hex 32
# Store on Mac with: security add-generic-password -U -s "com.agentkvt.runner" -a "webhook_secret" -w "<value>"
MAC_AGENT_WEBHOOK_SECRET=
