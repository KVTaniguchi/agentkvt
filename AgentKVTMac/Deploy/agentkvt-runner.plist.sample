<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App bundles default to scheduler mode automatically, but keeping this explicit is fine. -->
    <key>RUN_SCHEDULER</key>
    <true/>

    <!-- Recommended for the current strongest-model Ollama path. -->
    <key>OLLAMA_MODEL</key>
    <string>qwen3.6:35b</string>

    <!-- Optional overrides -->
    <key>OLLAMA_BASE_URL</key>
    <string>http://localhost:11434</string>
    <!-- Ollama web search/fetch: keep in THIS file (chmod 600), not in LaunchAgent plists. -->
    <!-- <key>OLLAMA_API_KEY</key><string>ollama_...</string> -->
    <!-- Backend API mode -->
    <!-- <key>AGENTKVT_API_BASE_URL</key><string>http://100.64.0.10:3000</string> -->
    <!-- <key>AGENTKVT_WORKSPACE_SLUG</key><string>default</string> -->
    <!-- <key>AGENTKVT_AGENT_TOKEN</key><string>replace-me</string> -->
    <!-- Required when the API runs on another machine: URL the server can POST to for task dispatch (Tailscale/LAN/ngrok + WEBHOOK_PORT path). -->
    <!-- <key>AGENTKVT_AGENT_WEBHOOK_PUBLIC_URL</key><string>http://100.x.x.x:8765</string> -->
    <!-- <key>AGENTKVT_DISABLE_CLOUDKIT</key><true/> -->
    <key>SCHEDULER_INTERVAL_SECONDS</key>
    <integer>30</integer>
    <key>WEBHOOK_PORT</key>
    <integer>8765</integer>

    <!-- Optional path overrides -->
    <!-- <key>AGENTKVT_INBOX_DIR</key><string>/Users/familyagent/.agentkvt/inbox</string> -->
    <!-- <key>AGENTKVT_INBOUND_DIR</key><string>/Users/familyagent/.agentkvt/inbound</string> -->

    <!-- Optional integrations -->
    <!-- <key>NOTIFICATION_EMAIL</key><string>you@example.com</string> -->
    <!-- AgentMail inbox backend -->
    <!-- <key>AGENTMAIL_API_KEY</key><string>am_...</string> -->
    <!-- Optional fixed inbox id. If omitted, AgentKVT will create or reuse one via AgentMail and remember it locally. -->
    <!-- <key>AGENTMAIL_INBOX_ID</key><string>agent@agentmail.to</string> -->
    <!-- Optional inbox creation hints -->
    <!-- <key>AGENTMAIL_DISPLAY_NAME</key><string>Agent KVT</string> -->
    <!-- <key>AGENTMAIL_USERNAME</key><string>agentkvt</string> -->
    <!-- <key>AGENTMAIL_DOMAIN</key><string>agentmail.to</string> -->
    <!-- <key>AGENTMAIL_INBOX_CLIENT_ID</key><string>agentkvt-email-v1</string> -->
    <!-- Python interpreter that has `pip install agentmail` available -->
    <!-- <key>AGENTMAIL_PYTHON_EXECUTABLE</key><string>/Users/familyagent/.venvs/agentmail/bin/python3</string> -->
    <!-- <key>AGENTMAIL_POLL_SECONDS</key><integer>60</integer> -->
    <!-- <key>GITHUB_AGENT_PAT</key><string>ghp_...</string> -->
    <!-- <key>GITHUB_AGENT_REPOS</key><array><string>owner/repo-one</string><string>owner/repo-two</string></array> -->
</dict>
</plist>
